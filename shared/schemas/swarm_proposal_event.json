{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SwarmProposalEvent",
  "type": "object",
  "properties": {
    "proposalId": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "integer" },
    "action": { "type": "string", "enum": ["REBALANCE", "MINT_RWA", "HALT_PROTOCOL"] },
    "payload": {
      "type": "object",
      "properties": {
        "targetAsset": { "type": "string" },
        "allocationWeightDelta": { "type": "number" },
        "executionPath": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["targetAsset", "allocationWeightDelta"]
    },
    "signatures": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "agentId": { "type": "string" },
          "vote": { "type": "string", "enum": ["APPROVE", "REJECT"] },
          "cryptographicProof": { "type": "string" }
        },
        "required": ["agentId", "vote", "cryptographicProof"]
      }
    }
  },
  "required": ["proposalId", "timestamp", "action", "payload", "signatures"]
}
